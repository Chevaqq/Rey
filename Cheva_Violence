-- Fungsi Deteksi Role Universal (Mengecek Team, Atribut, Nama, atau Tools)
local function GetPlayerRole(plr)
    if not plr or not plr.Character then return "Survivor" end
    
    -- Cek string atribut yang umum di game DBD/Horor Roblox
    if plr:GetAttribute("Role") == "Killer" or plr.Character:GetAttribute("Role") == "Killer" then
        return "Killer"
    end
    -- Cek nama team jika ada
    if plr.Team and (plr.Team.Name:lower():find("killer") or plr.Team.Name:lower():find("murder")) then
        return "Killer"
    end
    -- Cek jika memegang senjata/item pembunuh
    if plr.Character:FindFirstChildOfClass("Tool") and (plr.Character:FindFirstChildOfClass("Tool").Name:lower():find("knife") or plr.Character:FindFirstChildOfClass("Tool").Name:lower():find("weapon")) then
        return "Killer"
    end
    -- Cek string nama player
    if plr.Name:lower():find("killer") then
        return "Killer"
    end
    
    return "Survivor"
end

