CreateInput(PageMain, "Char Me (Ketik Username & Tekan Enter)", "Username Roblox...", function(text)
    local targetUserId = nil
    pcall(function()
        targetUserId = Players:GetUserIdFromNameAsync(text)
    end)
    if targetUserId and LocalPlayer.Character then
        local humDescription = Players:GetHumanoidDescriptionFromUserId(targetUserId)
        if humDescription then
            LocalPlayer.Character:WaitForChild("Humanoid"):ApplyDescription(humDescription)
        end
    end
end)

CreateInput(PageMain, "Speed Hack (Ketik angka & Enter)", "Contoh: 50", function(text)
    local speed = tonumber(text)
    if speed and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = speed
    end
end)

