-- LOGIC FITUR: TAB VISUAL (Chams Tanpa Isi/Hanya Garis Tepi & Generator)
-- =============================================================================
local function ApplyChams(instance, color, flagName)
    if not instance:FindFirstChild("ChevaHighlight") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ChevaHighlight"
        highlight.FillTransparency = 1 -- 1 berarti tengahnya transparan bersih
        highlight.OutlineColor = color
        highlight.OutlineTransparency = 0
        highlight.Adornee = instance
        highlight.Parent = instance
        
        task.spawn(function()
            while task.wait(0.5) do
                if not _G[flagName] then
                    highlight:Destroy()
                    break
                end
            end
        end)
    end
end

