-- LOGIC FITUR: TAB SURVIVOR
-- =============================================================================
CreateToggle(PageSurvivor, "Aimlock (Lock Killer Only)", false, function(val)
    AimlockEnabled = val
    if AimlockEnabled then
        task.spawn(function()
            while AimlockEnabled do
                task.wait()
                local closestKiller = nil
                local shortestDistance = math.huge
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and GetPlayerRole(p) == "Killer" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                        if dist < shortestDistance then
                            shortestDistance = dist
                            closestKiller = p.Character.HumanoidRootPart
                        end
                    end
                end
                if closestKiller and workspace.CurrentCamera then
                    workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, closestKiller.Position)
                end
            end
        end)
    end
end)

CreateToggle(PageSurvivor, "Enable FOV Ring", false, function(val)
    FOVEnabled = val
end)

CreateInput(PageSurvivor, "FOV Size", "Contoh: 120", function(text)
    local size = tonumber(text)
    if size then FOVSize = size end
end)

CreateInput(PageSurvivor, "FOV Color (Format R,G,B)", "255,0,0", function(text)
    local r, g, b = text:match("(%d+),(%d+),(%d+)")
    if r and g and b then
        FOVColor = Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
    end
end)

