-- Helper: Deteksi Role Player
local function GetPlayerRole(plr)
    if plr.Character then
        if plr.Character:AttributeString("Role") == "Killer" or plr.Name:lower():find("killer") then
            return "Killer"
        end
    end
    return "Survivor"
end

