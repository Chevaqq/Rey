CreateInput(PageMain, "Char Me (Ketik Username & Tekan Enter)", "Username Roblox...", function(text)
    local targetUserId = nil
    pcall(function()
        targetUserId = Players:GetUserIdFromNameAsync(text)
    end)
    if targetUserId and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        local humDescription = Players:GetHumanoidDescriptionFromUserId(targetUserId)
        if humDescription then
            -- Memaksa pergantian description pakaian dan bentuk tubuh secara instan
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ApplyDescription(humDescription)
        end
    end
end)

