-- [[ PILTER ROLE & DETEKSI TARGET ]] --
local function IsKillerPlayer(player)
    if player:GetAttribute("Role") == "Killer" or player.Name:lower():find("killer") or (player.Character and player.Character:FindFirstChild("Tombak")) then
        return true
    end
    return false
end

local function GetClosestTarget(targetType)
    local Target = nil
    local ShortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local isKiller = IsKillerPlayer(v)
                local isValid = false
                
                if targetType == "KillerOnly" and isKiller then
                    isValid = true
                elseif targetType == "SurvivorOnly" and not isKiller then
                    isValid = true
                end

                if isValid then
                    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                    if OnScreen then
                        local MousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                        local Mag = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                        if Mag < ShortestDistance then
                            ShortestDistance = Mag
                            Target = v
                        end
                    end
                end
            end
        end
    end
    return Target
end

-- [[ CHAMS VISUALS ]] --
local function ApplyChams(player, color)
    if player.Character then
        local Highlight = player.Character:FindFirstChildOfClass("Highlight")
        if not Highlight then
            Highlight = Instance.new("Highlight")
            Highlight.Parent = player.Character
        end
        Highlight.FillColor = color
        Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        Highlight.FillTransparency = 0.4
        Highlight.OutlineTransparency = 0
        Highlight.Enabled = true
    end
end

local function RemoveChams(player)
    if player.Character then
        local Highlight = player.Character:FindFirstChildOfClass("Highlight")
        if Highlight then Highlight:Destroy() end
    end
end

-- [[ LINE TRACER ]] --
local LineDrawing = Drawing.new("Line")
LineDrawing.Visible = false
LineDrawing.Color = Color3.fromRGB(0, 255, 0)
LineDrawing.Thickness = 2

-- [[ RENDERING LOOP ]] --
RunService.RenderStepped:Connect(function()
    if not Config.KeyVerified then return end

    if Config.SilentAimVeil or Config.AimbotVeil then
        CurrentTarget = GetClosestTarget("SurvivorOnly")
    elseif Config.SilentAimSurvivor then
        CurrentTarget = GetClosestTarget("KillerOnly")
    else
        CurrentTarget = nil
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local killerCheck = IsKillerPlayer(p)
            if Config.ChamsKiller and killerCheck then
                ApplyChams(p, Color3.fromRGB(255, 0, 0))
            elseif Config.ChamsSurvivor and not killerCheck then
                ApplyChams(p, Color3.fromRGB(0, 255, 0))
            else
                RemoveChams(p)
            end
        end
    end

    if Config.AimbotVeil and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, CurrentTarget.Character.HumanoidRootPart.Position)
    end

    if Config.ShowVeilLine and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(CurrentTarget.Character.HumanoidRootPart.Position)
        if OnScreen then
            LineDrawing.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            LineDrawing.To = Vector2.new(ScreenPos.X, ScreenPos.Y)
            LineDrawing.Visible = true
        else
            LineDrawing.Visible = false
        end
    else
        LineDrawing.Visible = false
    end
end)


-- [[ FIXED & INDEPENDENT SILENT AIM ENGINE ]] --
-- Menggunakan sistem penyaringan nama objek agar interaksi jendela, gene, dan angkat tubuh tidak ikut terganggu!

local OldIndex
OldIndex = hookmetamethod(game, "__index", function(Self, Key)
    if not checkcaller() and Key == "Clips" or Key == "Hitbox" then
        if CurrentTarget and CurrentTarget.Character then
            -- Bypass deteksi anti-cheat internal dasar game jika ada
            return OldIndex(Self, Key)
        end
    end
    return OldIndex(Self, Key)
end)

local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()
    local CallingScript = getcallingscript() and getcallingscript().Name:lower() or ""

    if not checkcaller() and (Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRay" or Method == "Raycast") then
        
        -- SISTEM FILTERISASI: Jika Raycast dipicu oleh fungsi interaksi lingkungan, abaikan pembelokan aim!
        local SelfName = Self.Name:lower()
        if SelfName:find("window") or SelfName:find("jendela") or SelfName:find("generator") or SelfName:find("gene") or SelfName:find("interact") or CallingScript:find("interact") then
            return OldNamecall(Self, unpack(Args))
        end

        if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local ShouldRedirect = false
            
            if Config.SilentAimSurvivor and IsKillerPlayer(CurrentTarget) then
                ShouldRedirect = true
            elseif Config.SilentAimVeil and not IsKillerPlayer(CurrentTarget) then
                ShouldRedirect = true
            end

            if ShouldRedirect then
                local TargetPart = CurrentTarget.Character.HumanoidRootPart
                
                -- ULTRA OP PREDIKSI: Menghitung jarak + manipulasi kecepatan konstan proyektil game
                local Velocity = TargetPart.AssemblyLinearVelocity
                local Distance = (TargetPart.Position - Camera.CFrame.Position).Magnitude
                
                -- Formula prediksi otomatis dinamis
                local PredictionTime = Distance / 850
                local PredictedPosition = TargetPart.Position + (Velocity * PredictionTime) + Vector3.new(0, 0.2, 0) -- Ditambah sedikit offset dada agar pas hantaman proyektil

                -- Memaksa Raycast peluru/tombak mengarah 100% ke target hasil prediksi
                if Args[1] and typeof(Args[1]) == "Ray" then
                    Args[1] = Ray.new(Args[1].Origin, (PredictedPosition - Args[1].Origin).Unit * 9999)
                elseif Method == "Raycast" and typeof(Args[1]) == "Vector3" and typeof(Args[2]) == "Vector3" then
                    Args[2] = (PredictedPosition - Args[1]).Unit * 9999
                end
            end
        end
    end
    return OldNamecall(Self, unpack(Args))
end)
