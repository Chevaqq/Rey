-- Mencari Target Kepala Killer
local function GetKillerHead()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            if string.find(string.lower(p.Name), "killer") or string.find(string.lower(p.Character.Name), "killer") then
                return p.Character.Head
            end
        end
    end
    -- Cadangan jika nama disembunyikan game
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("Head") and obj ~= LocalPlayer.Character then
            if obj:FindFirstChild("Knife") or string.find(string.lower(obj.Name), "killer") then
                return obj.Head
            end
        end
    end
    return nil
end

-- Mekanik Jalannya Moonwalk
local function UpdateMoonwalkState()
    if moonwalkActive then
        if moonwalkConnection then moonwalkConnection:Disconnect() end
        moonwalkConnection = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
                local hum = char.Humanoid
                local root = char.HumanoidRootPart
                hum.AutoRotate = false
                
                if hum.MoveDirection.Magnitude > 0 then
                    local lookVector = Camera.CFrame.LookVector
                    local moveDir = hum.MoveDirection
                    local dotProduct = moveDir:Dot(Vector3.new(lookVector.X, 0, lookVector.Z).Unit)
                    
                    if currentMoonwalkMode == 1 then
                        root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                    elseif currentMoonwalkMode == 2 then
                        if dotProduct > 0 then
                            root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                        else
                            root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(lookVector.X, 0, lookVector.Z))
                        end
                    end
                end
            end
        end)
    else
        if moonwalkConnection then moonwalkConnection:Disconnect() end
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.AutoRotate = true
        end
    end
end

-- MEKANIK SILENT AIM REDIRECTION (TELEPORT JALUR PELURU ANTI-MISS)
local OldFindPartOnRay = workspace.FindPartOnRay
local OldRaycast = workspace.Raycast

-- Hook metatable raycast workspace agar arah tembakan peluru angin ter-teleport otomatis ke Killer
local gmt = getrawmetatable(game)
local oldNamecall = gmt.__namecall
setreadonly(gmt, false)

gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if silentAimActive and (method == "Raycast" or method == "FindPartOnRay" or method == "findPartOnRay") then
        local targetHead = GetKillerHead()
        if targetHead then
            -- Paksa titik jatuhnya peluru/raycast langsung mengarah akurat ke kepala Killer
            if method == "Raycast" then
                args[2] = (targetHead.Position - args[1]).Unit * 1000
                return OldRaycast(self, table.unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(gmt, true)


