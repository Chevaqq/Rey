-- [[ UTILITIES ]] --
local function IsKillerPlayer(player)
    if player:GetAttribute("Role") == "Killer" or player.Name:lower():find("killer") or (player.Character and player.Character:FindFirstChild("Tombak")) then
        return true
    end
    return false
end

-- Fungsi Membuat Tracer Line 3D Menggunakan Beam bawaan Roblox (Pasti Muncul di HP)
local function Create3DTracer(startPart, endPart, color)
    local att0 = Instance.new("Attachment", startPart)
    local att1 = Instance.new("Attachment", endPart)
    
    local beam = Instance.new("Beam", startPart)
    beam.Attachment0 = att0
    beam.Attachment1 = att1
    beam.Color = ColorSequence.new(color)
    beam.FaceCamera = true
    beam.Width0 = 0.4
    beam.Width1 = 0.4
    
    -- Menghilang secara instan setelah hantaman peluru selesai (sepersekian detik)
    task.wait(0.08)
    beam:Destroy()
    att0:Destroy()
    att1:Destroy()
end

-- [[ RENDERING LOOP ENGINE ]] --
RunService.RenderStepped:Connect(function()
    if not Config.KeyVerified then return end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local Root = p.Character.HumanoidRootPart
            local killerCheck = IsKillerPlayer(p)

            -- 1. SISTEM CHAMS
            local Highlight = p.Character:FindFirstChildOfClass("Highlight")
            if Config.ChamsKiller and killerCheck then
                if not Highlight then
                    Highlight = Instance.new("Highlight", p.Character)
                end
                Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                Highlight.FillTransparency = 0.4
                Highlight.Enabled = true
            elseif Config.ChamsSurvivor and not killerCheck then
                if not Highlight then
                    Highlight = Instance.new("Highlight", p.Character)
                end
                Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                Highlight.FillTransparency = 0.4
                Highlight.Enabled = true
            else
                if Highlight then Highlight:Destroy() end
            end

            -- 2. ULTRA HITBOX EXPANSION (Sistem Pengganti Silent Aim / Prediksi Anti-Miss Tanpa Stuck)
            if Config.SilentAimSurvivor and killerCheck then
                -- Survivor mengincar Killer: Perbesar hitbox Killer
                Root.Size = OPSize
                Root.Transparency = 0.7 -- Sedikit transparan agar kamu tahu areanya meluas
                Root.CanCollide = false
            elseif Config.SilentAimVeil and not killerCheck then
                -- Killer mengincar Survivor: Perbesar hitbox Survivor
                Root.Size = OPSize
                Root.Transparency = 0.7
                Root.CanCollide = false
            else
                -- Kembalikan ke ukuran normal jika fitur mati
                Root.Size = DefaultSize
                Root.Transparency = 0
                Root.CanCollide = true
            end
        end
    end
end)

-- [[ DETEKSI KETIKA TOMBOL TEMBAK/AKSI DITEKAN UNTUK LINE TRACER SURVIVOR ]] --
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not Config.KeyVerified or not Config.SilentAimSurvivor then return end
    
    -- Mendeteksi sentuhan layar (Touch) atau klik mouse di HP saat menembak
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        
        -- Cari Killer terdekat untuk ditarik garis orange
        local ClosestKiller = nil
        local ShortestDistance = math.huge
        
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and IsKillerPlayer(v) then
                local Dist = (v.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if Dist < ShortestDistance then
                    ShortestDistance = Dist
                    ClosestKiller = v
                end
            end
        end
        
        -- Jika killer ditemukan, buat garis orange instan yang akan hilang saat peluru mengenai target
        if ClosestKiller and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            task.spawn(function()
                Create3DTracer(LocalPlayer.Character.HumanoidRootPart, ClosestKiller.Character.HumanoidRootPart, Color3.fromRGB(255, 110, 0))
            end)
        end
    end
end)
