local function getSafeContainer()
    local success, cGui = pcall(function() return CoreGui end)
    if success and cGui and not cGui:FindFirstChild("RCA_CyberCore_Premium") then 
        return cGui 
    end
    local pGui = LocalPlayer:WaitForChild("PlayerGui", 5)
    return pGui
end

