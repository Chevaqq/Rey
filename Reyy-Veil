-- --- DETEKSI TARGET (LOCK KILLER ONLY) ---
local function IsKiller(player)
    if player == LocalPlayer then return false end
    
    -- 1. Berdasarkan Tim Resmi
    if player.Team and (player.Team.Name:lower():find("killer") or player.Team.Name:lower():find("slasher")) then
        return true
    end
    
    -- 2. Berdasarkan Tool yang dipegang (Pisau/Senjata)
    local character = player.Character
    if character then
        for _, item in pairs(character:GetChildren()) do
            if item:IsA("Tool") and (item.Name:lower():find("knife") or item.Name:lower():find("weapon") or item.Name:lower():find("murd")) then
                return true
            end
        end
    end
    
    return false
end

-- --- MENCARI KILLER TERDEKAT ---
local function GetClosestKiller()
    local closestTarget = nil
    local shortestDistance = math.huge

    for _, player in pairs(Players:GetPlayers()) do
        if IsKiller(player) then
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if rootPart and humanoid and humanoid.Health > 0 then
                local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    local distance = (rootPart.Position - myRoot.Position).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestTarget = rootPart
                    end
                end
            end
        end
    end
    return closestTarget
end

-- --- SILENT AIM ENGINE V3 (ADVANCED METAMETHOD HOOK) ---
-- Membelokkan peluru secara matematis tanpa mengunci pergerakan kamera utama kamu
local gmt = getrawmetatable(game)
setreadonly(gmt, false)
local oldNamecall = gmt.__namecall

gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if ScriptConfig.SilentAimEnabled and not checkcaller() then
        if method == "Raycast" or method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" then
            local targetPart = GetClosestKiller()
            if targetPart then
                if method == "Raycast" then
                    -- args[1] = Origin, args[2] = Direction
                    local origin = args[1]
                    args[2] = (targetPart.Position - origin).Unit * 1000
                elseif method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList" then
                    -- args[1] = Ray
                    local origin = args[1].Origin
                    args[1] = Ray.new(origin, (targetPart.Position - origin).Unit * 1000)
                end
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(gmt, true)


