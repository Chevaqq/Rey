-- [[ UTILITIES ]] --
local function IsSurvivor(player)
    if player ~= LocalPlayer and player:GetAttribute("Role") ~= "Killer" and not player.Name:lower():find("killer") then
        return true
    end
    return false
end

local function CheckIfHoldingSpear()
    local Char = LocalPlayer.Character
    if Char then
        for _, tool in pairs(Char:GetChildren()) do
            if tool:IsA("Tool") or tool.Name:lower():find("tombak") or tool.Name:lower():find("spear") then
                return true
            end
        end
    end
    return false
end

local function GetClosestSurvivor()
    local Target = nil
    local ShortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if IsSurvivor(v) and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if OnScreen then
                    local MousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local Mag = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                    if Mag < ShortestDistance then
                        ShortestDistance = Mag
                        Target = v
                    end
                end
            end
        end
    end
    return Target
end


-- [[ OPTIMIZED LIGHT RENDER LOOP ]] --
RunService.RenderStepped:Connect(function()
    if not Config.ChamsSurvivor then return end

    -- Loop Chams dioptimalkan agar tidak memicu memory leak atau lag patah-patah
    for _, p in pairs(Players:GetPlayers()) do
        if IsSurvivor(p) and p.Character then
            local Highlight = p.Character:FindFirstChildOfClass("Highlight")
            if not Highlight then
                Highlight = Instance.new("Highlight")
                Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                Highlight.FillTransparency = 0.5
                Highlight.OutlineTransparency = 0
                Highlight.Parent = p.Character
            end
        end
    end
end)


-- [[ ONE-TAP ATTACK TRIGGER (ANTI-STUCK & ANTI-MISS) ]] --
-- Fungsi ini hanya berjalan SATU KALI saat layar disentuh untuk menyerang, 
-- sehingga performa HP tetap 100% lancar dan bebas lag patah-patah.
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not Config.SilentAimVeil or gameProcessed then return end

    -- Mendeteksi ketukan di HP (Touch) atau klik layar saat melempar tombak
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if CheckIfHoldingSpear() then
            local Target = GetClosestSurvivor()
            
            if Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
                local TargetRoot = Target.Character.HumanoidRootPart
                
                -- Kalkulasi prediksi arah gerak instan
                local TargetVelocity = TargetRoot.AssemblyLinearVelocity
                local PredictedPos = TargetRoot.Position + (TargetVelocity * 0.15)
                
                -- Point-Lock Instan: Mengarahkan kamera tepat ke arah target hanya selama 1 frame saat menyerang
                -- Jari kamu tidak akan pernah stuck karena kontrol langsung dikembalikan ke tangan kamu seketika setelah menyerang
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, PredictedPos)
                
                -- Mengarahkan proyektil tombak secara internal ke koordinat target
                local Weapon = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if Weapon and Weapon:FindFirstChild("Handle") then
                    task.spawn(function()
                        -- Memastikan bagian peluncur alat sejajar dengan target agar tidak miss
                        Weapon.Handle.CFrame = CFrame.lookAt(Weapon.Handle.Position, PredictedPos)
                    end)
                end
            end
        end
    end
end)
