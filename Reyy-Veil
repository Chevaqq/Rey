-- [2] LOGIKA PERGERAKAN MOONWALK ZENTAZZ STYLE
local function ApplyMoonwalk()
    if moonwalkConnection then moonwalkConnection:Disconnect() end
    
    moonwalkConnection = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            
            if hum and root then
                hum.AutoRotate = false
                
                if hum.MoveDirection.Magnitude > 0 then
                    local lookVector = Camera.CFrame.LookVector
                    local moveDir = hum.MoveDirection
                    
                    -- Kalkulasi apakah analog ditekan maju atau mundur relatif terhadap kamera
                    local dotProduct = moveDir:Dot(Vector3.new(lookVector.X, 0, lookVector.Z).Unit)
                    
                    if currentMode == 1 then
                        -- MODE 1: Karakter selalu dipaksa menghadap ke belakang kamera (Mundur total)
                        root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                    elseif currentMode == 2 then
                        -- MODE 2: Responsif bolak-balik (Maju jadi mundur, mundur jadi maju)
                        if dotProduct > 0 then
                            -- Jika analog ditekan maju, badan menghadap ke belakang
                            root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                        else
                            -- Jika analog ditekan mundur, badan menghadap ke depan kamera
                            root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(lookVector.X, 0, lookVector.Z))
                        end
                    end
                end
            end
        end
    end)
end

local function RemoveMoonwalk()
    if moonwalkConnection then
        moonwalkConnection:Disconnect()
        moonwalkConnection = nil
    end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate = true end
    end
end

-- Auto-On kembali jika karakter respawn/masuk match baru
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if moonwalkActive then
        ApplyMoonwalk()
    end
end)


