-- Tombol Start / Stop Moonwalk
StartBtn.MouseButton1Click:Connect(function()
    moonwalkActive = not moonwalkActive
    if moonwalkActive then
        StartBtn.Text = "STOP"
        StartBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 60) -- Hijau saat aktif
        ApplyMoonwalk()
    else
        StartBtn.Text = "START"
        StartBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60) -- Merah saat mati
        RemoveMoonwalk()
    end
end)

-- Tombol Switch Mode (Mode 1 / Mode 2)
ModeBtn.MouseButton1Click:Connect(function()
    if currentMode == 1 then
        currentMode = 2
        ModeBtn.Text = "MODE: 2"
    else
        currentMode = 1
        ModeBtn.Text = "MODE: 1"
    end
    
    -- Update instan jika moonwalk sedang menyala
    if moonwalkActive then
        ApplyMoonwalk()
    end
end)
