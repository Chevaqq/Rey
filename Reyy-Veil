-- Fungsi Lacak Kepala Killer Terdekat dalam FOV
local function GetClosestKillerInFOV()
    local target = nil
    local shortestDistance = math.huge
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            -- Cari entitas bertindak sebagai killer
            if string.find(string.lower(p.Name), "killer") or string.find(string.lower(p.Character.Name), "killer") or p.Character:FindFirstChild("Knife") then
                local head = p.Character.Head
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    -- Hitung jarak dari posisi crosshair tengah HP ke target kepala Killer
                    local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if distance < shortestDistance and distance <= FOVCircle.Radius then
                        shortestDistance = distance
                        target = head
                    end
                end
            end
        end
    end
    return target
end

-- Ambil kontrol pergerakan Moonwalk
local function UpdateMoonwalk()
    if moonwalkActive then
        if moonwalkConnection then moonwalkConnection:Disconnect() end
        moonwalkConnection = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") and char:FindFirstChild("HumanoidRootPart") then
                local hum = char.Humanoid
                local root = char.HumanoidRootPart
                hum.AutoRotate = false
                
                if hum.MoveDirection.Magnitude > 0 then
                    local look = Camera.CFrame.LookVector
                    local dotProduct = hum.MoveDirection:Dot(Vector3.new(look.X, 0, look.Z).Unit)
                    
                    if currentMoonwalkMode == 1 then
                        root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(look.X, 0, look.Z))
                    elseif currentMoonwalkMode == 2 then
                        if dotProduct > 0 then
                            root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(look.X, 0, look.Z))
                        else
                            root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(look.X, 0, look.Z))
                        end
                    end
                end
            end
        end)
    else
        if moonwalkConnection then moonwalkConnection:Disconnect() end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.AutoRotate = true
        end
    end
end

-- HEAL AURA ENGINE (Violence District Remote Injector Bypass)
local function StartHealAura()
    if healAuraConnection then healAuraConnection:Disconnect() end
    healAuraConnection = RunService.Heartbeat:Connect(function()
        if healAuraActive and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            local hum = LocalPlayer.Character.Humanoid
            if hum.Health < hum.MaxHealth then
                -- Memaksa pengisian darah instan client-side & server remote fire bypass
                hum.Health = hum.MaxHealth
                
                -- Lacak trigger remote healing di game
                for _, v in pairs(game:GetDescendants()) do
                    if v:IsA("RemoteEvent") and (string.find(string.lower(v.Name), "heal") or string.find(string.lower(v.Name), "medkit") or string.find(string.lower(v.Name), "givehealth")) then
                        v:FireServer(LocalPlayer.Character, hum.MaxHealth)
                    end
                end
            end
        end
    end)
end

-- SILENT AIM METATABLE HOOKING (ANTI-MISS TOTAL)
local gmt = getrawmetatable(game)
local oldIndex = gmt.__index
local oldNamecall = gmt.__namecall
setreadonly(gmt, false)

-- Mengubah posisi hit mouse peluru di core engine secara real-time
gmt.__index = newcclosure(function(self, idx)
    if silentAimActive and tostring(self) == "Mouse" and (idx == "Hit" or idx == "Target") then
        local targetKiller = GetClosestKillerInFOV()
        if targetKiller then
            return (idx == "Hit" and targetKiller.CFrame or targetKiller)
        end
    end
    return oldIndex(self, idx)
end)

-- Mengubah arah Raycast senjata game agar belok otomatis 
gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if silentAimActive and (method == "Raycast" or method == "FindPartOnRay") then
        local targetKiller = GetClosestKillerInFOV()
        if targetKiller then
            if method == "Raycast" then
                args[2] = (targetKiller.Position - args[1]).Unit * 1000
                return oldNamecall(self, table.unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(gmt, true)

