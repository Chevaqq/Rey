-- SILENT AIM FIXED (Kamera bebas bergerak, Tembakan otomatis mengunci target Killer)
local OldIndex
OldIndex = hookmetamethod(game, "__index", function(self, key)
    if Features.SilentAim and not checkcaller() then
        -- Membelokkan arah mouse/kursor client saat menembak tanpa mengunci pergerakan layar
        if self:IsA("PlayerMouse") and (key == "Hit" or key == "Target") then
            local killerPart = getClosestKiller()
            if killerPart then
                if key == "Hit" then
                    return killerPart.CFrame
                elseif key == "Target" then
                    return killerPart
                end
            end
        end
    end
    return OldIndex(self, key)
end)

-- Cadangan untuk senjata berbasis Raycast agar peluru langsung tembus ke Killer
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if Features.SilentAim and not checkcaller() and (method == "Raycast" or method == "FindPartOnRayWithIgnoreList") then
        local killerPart = getClosestKiller()
        if killerPart then
            if method == "FindPartOnRayWithIgnoreList" then
                args[1] = Ray.new(Camera.CFrame.Position, (killerPart.Position - Camera.CFrame.Position).Unit * 1500)
                return OldNamecall(self, unpack(args))
            end
        end
    end
    return OldNamecall(self, ...)
end)
