-- Fungsi Mencari Karakter Killer di Map
local function GetKillerInstance()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            -- Cek nama player atau objek yang mengandung unsur kata killer
            if string.find(string.lower(p.Name), "killer") or string.find(string.lower(p.Character.Name), "killer") then
                return p.Character
            end
        end
    end
    -- Jika nama player disembunyikan game, lacak model apa pun di Workspace yang memegang senjata killer
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and obj ~= LocalPlayer.Character then
            if obj:FindFirstChild("Knife") or obj:FindFirstChild("Weapon") or string.find(string.lower(obj.Name), "killer") then
                return obj
            end
        end
    end
    return nil
end

-- Loop Moonwalk (Mode 1 & Mode 2 Bergerak Bebas Maju Mundur)
local function StartMoonwalk()
    if moonwalkConnection then moonwalkConnection:Disconnect() end
    moonwalkConnection = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if hum and root then
                hum.AutoRotate = false
                if hum.MoveDirection.Magnitude > 0 then
                    local lookVector = Camera.CFrame.LookVector
                    local moveDir = hum.MoveDirection
                    local dotProduct = moveDir:Dot(Vector3.new(lookVector.X, 0, lookVector.Z).Unit)
                    
                    if currentMoonwalkMode == 1 then
                        -- Mode 1: Kunci hadap kebalikan kamera (Mundur konstan)
                        root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                    elseif currentMoonwalkMode == 2 then
                        -- Mode 2: Dinamis mengikuti gerak analog maju-mundur
                        if dotProduct > 0 then
                            root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                        else
                            root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(lookVector.X, 0, lookVector.Z))
                        end
                    end
                end
            end
        end
    end)
end

local function StopMoonwalk()
    if moonwalkConnection then moonwalkConnection:Disconnect() end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate = true end
    end
end

-- Loop Silent Aim Fix (Sistem Hitbox Ekspander + Teleport Target ke Depan Peluru)
local function StartSilentAim()
    if silentAimConnection then silentAimConnection:Disconnect() end
    silentAimConnection = RunService.RenderStepped:Connect(function()
        if silentAimActive then
            local killerChar = GetKillerInstance()
            if killerChar and killerChar:FindFirstChild("Head") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                -- Bikin ukuran Head Killer super besar (Hitbox) secara client agar peluru anginmu tidak pernah meleset
                killerChar.Head.Size = Vector3.new(15, 15, 15)
                killerChar.Head.CanCollide = false
                if killerChar:FindFirstChild("HumanoidRootPart") then
                    killerChar.HumanoidRootPart.Size = Vector3.new(15, 15, 15)
                    killerChar.HumanoidRootPart.CanCollide = false
                end
            end
        end
    end)
end

local function StopSilentAim()
    if silentAimConnection then silentAimConnection:Disconnect() end
    local killerChar = GetKillerInstance()
    if killerChar and killerChar:FindFirstChild("Head") then
        -- Kembalikan ukuran asli jika dimatikan
        killerChar.Head.Size = Vector3.new(2, 2, 2)
        if killerChar:FindFirstChild("HumanoidRootPart") then
            killerChar.HumanoidRootPart.Size = Vector3.new(2, 2, 2)
        end
    end
end


