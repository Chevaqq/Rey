-- Notification Function
local function ShowNotification(text)
    local Notif = Instance.new("TextLabel")
    Notif.Size = UDim2.new(0, 250, 0, 40)
    Notif.Position = UDim2.new(0.5, -125, 0.1, 0)
    Notif.BackgroundColor3 = Color3.fromRGB(10, 10, 20)
    Notif.TextColor3 = Color3.fromRGB(0, 150, 255)
    Notif.TextSize = 16
    Notif.Font = Enum.Font.Code
    Notif.Text = "[!] " .. text
    Notif.BorderSizePixel = 2
    Notif.BorderColor3 = Color3.fromRGB(0, 80, 200)
    Notif.Parent = ScreenGui
    
    local UIStroke = Instance.new("UIStroke")
    UIStroke.Thickness = 1
    UIStroke.Color = Color3.fromRGB(0,0,0)
    UIStroke.Parent = Notif

    task.delay(2, function()
        TweenService:Create(Notif, TweenInfo.new(0.5), {ImageTransparency = 1, TextTransparency = 1}):Play()
        task.wait(0.5)
        Notif:Destroy()
    end)
end

