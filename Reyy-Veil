-- [[ UTILITIES & ROLE SEPARATION ]] --
local function IsKillerPlayer(player)
    if player:GetAttribute("Role") == "Killer" or player.Name:lower():find("killer") or (player.Character and player.Character:FindFirstChild("Tombak")) then
        return true
    end
    return false
end

local function GetClosestTarget(targetType)
    local Target = nil
    local ShortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local isKiller = IsKillerPlayer(v)
                local isValid = false
                
                if targetType == "KillerOnly" and isKiller then
                    isValid = true
                elseif targetType == "SurvivorOnly" and not isKiller then
                    isValid = true
                end

                if isValid then
                    local Dist = (v.Character.HumanoidRootPart.Position - Camera.CFrame.Position).Magnitude
                    if Dist < ShortestDistance then
                        ShortestDistance = Dist
                        Target = v
                    end
                end
            end
        end
    end
    return Target
end

-- [[ INTERFACE DRAWING UNTUK TRACER LINE ORANGE MOBILE ]] --
local CanvasGui = Instance.new("Folder")
CanvasGui.Name = "ReyHub_Tracers"
CanvasGui.Parent = ScreenGui

local function DrawMobileTracer(startPos3D, endPos3D, color)
    local LineFrame = Instance.new("Frame")
    LineFrame.BackgroundColor3 = color
    LineFrame.BorderSizePixel = 0
    LineFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    LineFrame.Parent = CanvasGui

    local function UpdateLine()
        if not LineFrame or not LineFrame.Parent then return end
        local StartPos, StartOnScreen = Camera:WorldToViewportPoint(startPos3D)
        local EndPos, EndOnScreen = Camera:WorldToViewportPoint(endPos3D)

        if StartOnScreen and EndOnScreen then
            local Distance = (Vector2.new(EndPos.X, EndPos.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
            local Angle = math.atan2(EndPos.Y - StartPos.Y, EndPos.X - StartPos.X)

            LineFrame.Size = UDim2.new(0, Distance, 0, 3) -- Ketebalan garis 3px
            LineFrame.Position = UDim2.new(0, (StartPos.X + EndPos.X) / 2, 0, (StartPos.Y + EndPos.Y) / 2)
            LineFrame.Rotation = math.deg(Angle)
            LineFrame.Visible = true
        else
            LineFrame.Visible = false
        end
    end

    local Connection
    Connection = RunService.RenderStepped:Connect(UpdateLine)
    
    -- Efek kilat: Hilang otomatis setelah peluru mendarat (80 milidetik)
    task.delay(0.08, function()
        Connection:Disconnect()
        LineFrame:Destroy()
    end)
end

-- [[ CORE LOOP FOR VISUALS & DETEKSI PROYEKTIL ]] --
RunService.RenderStepped:Connect(function()
    if not Config.KeyVerified then return end

    -- Cari target berdasarkan peran saat ini
    if Config.SilentAimVeil then
        CurrentTarget = GetClosestTarget("SurvivorOnly")
    elseif Config.SilentAimSurvivor then
        CurrentTarget = GetClosestTarget("KillerOnly")
    else
        CurrentTarget = nil
    end

    -- Sistem Chams
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local Highlight = p.Character:FindFirstChildOfClass("Highlight")
            local killerCheck = IsKillerPlayer(p)

            if Config.ChamsKiller and killerCheck then
                if not Highlight then Highlight = Instance.new("Highlight", p.Character) end
                Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                Highlight.FillTransparency = 0.4
                Highlight.Enabled = true
            elseif Config.ChamsSurvivor and not killerCheck then
                if not Highlight then Highlight = Instance.new("Highlight", p.Character) end
                Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                Highlight.FillTransparency = 0.4
                Highlight.Enabled = true
            else
                if Highlight then Highlight:Destroy() end
            end
        end
    end

    -- FORCE TELEPORT TOMBAK/PELURU (Mekanik Anti-Miss Mutlak)
    -- Mencari objek proyektil baru yang muncul di Workspace untuk langsung dipindahkan ke target
    if Config.SilentAimVeil and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local TargetRoot = CurrentTarget.Character.HumanoidRootPart
        
        -- Memindai workspace untuk mencari objek bernama "Tombak" atau proyektil sejenis
        for _, obj in pairs(workspace:GetChildren()) do
            if obj:IsA("Part") or obj:IsA("Model") then
                local name = obj.Name:lower()
                if name:find("tombak") or name:find("spear") or name:find("projectile") then
                    -- Teleportasikan proyektil langsung ke dalam tubuh target agar memicu hit server
                    if obj:IsA("Part") then
                        obj.CFrame = TargetRoot.CFrame
                        obj.AssemblyLinearVelocity = Vector3.new(0, 0, 0) -- Hentikan inersia agar tidak melesat lewat
                    elseif obj:IsA("Model") and obj.PrimaryPart then
                        obj:SetPrimaryPartCFrame(TargetRoot.CFrame)
                    end
                end
            end
        end
    end
end)

-- [[ HOOK METAMETHOD UNTUK DETEKSI TEMBAKAN SURVIVOR & IMPLEMENTASI TRACER LINE ORANGE ]] --
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()

    if not checkcaller() and (Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRay" or Method == "Raycast") then
        if Config.SilentAimSurvivor and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            if IsKillerPlayer(CurrentTarget) then
                local TargetPart = CurrentTarget.Character.HumanoidRootPart
                local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

                -- Gambar Tracer Line Orange di Layar HP secara instan dari posisi karakter ke posisi target
                if MyRoot then
                    task.spawn(function()
                        DrawMobileTracer(MyRoot.Position, TargetPart.Position, Color3.fromRGB(255, 130, 0))
                    end)
                end

                -- Paksa jalur raycast peluru mengarah lurus 100% ke target tanpa deviasi/miss
                if Args[1] and typeof(Args[1]) == "Ray" then
                    Args[1] = Ray.new(Args[1].Origin, (TargetPart.Position - Args[1].Origin).Unit * 9999)
                elseif Method == "Raycast" and typeof(Args[1]) == "Vector3" and typeof(Args[2]) == "Vector3" then
                    Args[2] = (TargetPart.Position - Args[1]).Unit * 9999
                end
            end
        end
    end
    return OldNamecall(Self, unpack(Args))
end)
