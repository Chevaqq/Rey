    local IndicatorNode = Instance.new("Frame")
    IndicatorNode.Size = UDim2.new(0, 14, 0, 14)
    IndicatorNode.Position = UDim2.new(0.1, 0, 0.15, 0)
    IndicatorNode.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
    IndicatorNode.BorderSizePixel = 0
    IndicatorNode.Parent = Switch
    
    local isToggled = false
    Switch.MouseButton1Click:Connect(function()
        isToggled = not isToggled
        if isToggled then
            TweenService:Create(IndicatorNode, TweenInfo.new(0.15), {Position = UDim2.new(0.55, 0, 0.15, 0), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
            TweenService:Create(Switch, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(60, 60, 60), BorderColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        else
            TweenService:Create(IndicatorNode, TweenInfo.new(0.15), {Position = UDim2.new(0.1, 0, 0.15, 0), BackgroundColor3 = Color3.fromRGB(150, 150, 150)}):Play()
            TweenService:Create(Switch, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(30, 30, 30), BorderColor3 = Color3.fromRGB(100, 100, 100)}):Play()
        end
        callback(isToggled)
    end)
end

