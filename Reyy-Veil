-- [[ UTILITIES DETEKSI SURVIVOR ]] --
local function IsSurvivor(player)
    if player ~= LocalPlayer and player:GetAttribute("Role") ~= "Killer" and not player.Name:lower():find("killer") then
        return true
    end
    return false
end

local function GetClosestSurvivor()
    local Target = nil
    local ShortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if IsSurvivor(v) and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if OnScreen then
                    local MousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local Mag = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                    if Mag < ShortestDistance then
                        ShortestDistance = Mag
                        Target = v
                    end
                end
            end
        end
    end
    return Target
end

-- [[ REPLIKA 2D GRAPHICS LASER TRACER (SISTEM RINGAN HP) ]] --
local CanvasGui = Instance.new("Folder", ScreenGui)
CanvasGui.Name = "Zentazz_Tracers"

local function DrawLaserTracer(startPos3D, endPos3D)
    local LineFrame = Instance.new("Frame", CanvasGui)
    LineFrame.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Warna Hijau Tebal persis di video kamu
    LineFrame.BorderSizePixel = 0
    LineFrame.AnchorPoint = Vector2.new(0.5, 0.5)

    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not LineFrame or not LineFrame.Parent then return end
        local StartPos, StartOnScreen = Camera:WorldToViewportPoint(startPos3D)
        local EndPos, EndOnScreen = Camera:WorldToViewportPoint(endPos3D)

        if StartOnScreen and EndOnScreen then
            local Distance = (Vector2.new(EndPos.X, EndPos.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
            local Angle = math.atan2(EndPos.Y - StartPos.Y, EndPos.X - StartPos.X)

            LineFrame.Size = UDim2.new(0, Distance, 0, 4) -- Ketebalan 4px agar terlihat tegas seperti laser
            LineFrame.Position = UDim2.new(0, (StartPos.X + EndPos.X) / 2, 0, (StartPos.Y + EndPos.Y) / 2)
            LineFrame.Rotation = math.deg(Angle)
            LineFrame.Visible = true
        else
            LineFrame.Visible = false
        end
    end)
    
    -- Durasi kilatan laser saat tombak dilempar (0.12 detik lalu hancur agar tidak lag)
    task.delay(0.12, function()
        Connection:Disconnect()
        LineFrame:Destroy()
    end)
end


-- [[ MAIN LOOP ENGINE ]] --
RunService.RenderStepped:Connect(function()
    CurrentTarget = GetClosestSurvivor()

    -- 1. VISUAL ESP CHAMS (SILUET HIJAU TRANSURAN)
    for _, p in pairs(Players:GetPlayers()) do
        if IsSurvivor(p) and p.Character then
            local Highlight = p.Character:FindFirstChildOfClass("Highlight")
            if Config.ChamsSurvivor then
                if not Highlight then Highlight = Instance.new("Highlight", p.Character) end
                Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                Highlight.FillTransparency = 0.5
                Highlight.OutlineTransparency = 0
            else
                if Highlight then Highlight:Destroy() end
            end
        end
    end
end)


-- [[ METAMETHOD INTERCEPTION (VEIL CORE PREDICTION & ANTI-MISS) ]] --
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()

    -- Mendeteksi pemanggilan sistem tembakan/lemparan game
    if Config.SilentAimVeil and not checkcaller() and (Method == "Raycast" or Method == "FindPartOnRayWithIgnoreList") then
        if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local TargetRoot = CurrentTarget.Character.HumanoidRootPart
            local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            -- ALGORITMA PREDIKSI VEKTOR GERAKAN MUSUH
            -- Menghitung jarak, waktu tempuh proyektil, dan arah lari musuh secara matematis
            local Distance = (TargetRoot.Position - Camera.CFrame.Position).Magnitude
            local TimeToHit = Distance / Config.PredictSpeed
            local PredictedPos = TargetRoot.Position + (TargetRoot.AssemblyLinearVelocity * TimeToHit) + Vector3.new(0, 0.2, 0)

            -- MEMANCARKAN LASER TRACER HIJAU (Seketika saat serangan dilepas seperti di video)
            if MyRoot then
                task.spawn(function()
                    DrawLaserTracer(MyRoot.Position, PredictedPos)
                end)
            end

            -- MODIFIKASI JALUR TEMBAKAN SERVER (Memaksa Tombak Jatuh ke Titik Prediksi Target)
            if Method == "Raycast" and typeof(Args[1]) == "Vector3" and typeof(Args[2]) == "Vector3" then
                Args[2] = (PredictedPos - Args[1]).Unit * 9999
            elseif Args[1] and typeof(Args[1]) == "Ray" then
                Args[1] = Ray.new(Args[1].Origin, (PredictedPos - Args[1].Origin).Unit * 9999)
            end
        end
    end
    return OldNamecall(Self, unpack(Args))
end)
