-- [[ RENDERING LOOP (ANTI-STUCK FIX) ]] --
RunService.RenderStepped:Connect(function()
    if not Config.KeyVerified then return end

    -- Pembagian Target
    if Config.SilentAimVeil or Config.AimbotVeil then
        CurrentTarget = GetClosestTarget("SurvivorOnly")
    elseif Config.SilentAimSurvivor then
        CurrentTarget = GetClosestTarget("KillerOnly")
    else
        CurrentTarget = nil
    end

    -- Chams Loop
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local killerCheck = IsKillerPlayer(p)
            if Config.ChamsKiller and killerCheck then
                ApplyChams(p, Color3.fromRGB(255, 0, 0))
            elseif Config.ChamsSurvivor and not killerCheck then
                ApplyChams(p, Color3.fromRGB(0, 255, 0))
            else
                RemoveChams(p)
            end
        end
    end

    -- FIXED ANTI-STUCK AIMBOT: Menggunakan simulasi pergeseran input, bukan modifikasi paksa CFrame!
    if Config.AimbotVeil and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local TargetRoot = CurrentTarget.Character.HumanoidRootPart
        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(TargetRoot.Position)
        if OnScreen then
            -- Alih-alih membekukan CFrame, kita gunakan reposisi virtual center mouse ke arah target secara halus
            -- Ini membuat peluru/tombak otomatis mengunci arah target di HP tanpa mengunci jari jempolmu
            local Center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local MoveVector = (Vector2.new(ScreenPos.X, ScreenPos.Y) - Center) * 0.15
            -- Metode injeksi input internal (Aman dari stuck kamera)
            if typeof(setinputemulation) == "function" then
                setinputemulation(MoveVector.X, MoveVector.Y)
            end
        end
    end

    -- Killer Line (Garis Hijau)
    if Config.ShowVeilLine and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(CurrentTarget.Character.HumanoidRootPart.Position)
        if OnScreen then
            VeilLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            VeilLine.To = Vector2.new(ScreenPos.X, ScreenPos.Y)
            VeilLine.Visible = true
        else
            VeilLine.Visible = false
        end
    else
        VeilLine.Visible = false
    end
end)


-- [[ DYNAMIC ENGINE: ANTI-MISS & FLASH TRACER ORANGE ]] --
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()
    local CallingScript = getcallingscript() and getcallingscript().Name:lower() or ""

    if not checkcaller() and (Method == "FindPartOnRayWithIgnoreList" or Method == "FindPartOnRay" or Method == "Raycast") then
        
        -- Bypass interaksi jendela, gene, angkat orang agar tidak stuck peluru/fitur
        local SelfName = Self.Name:lower()
        if SelfName:find("window") or SelfName:find("jendela") or SelfName:find("generator") or SelfName:find("gene") or SelfName:find("interact") or CallingScript:find("interact") then
            return OldNamecall(Self, unpack(Args))
        end

        if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local ShouldRedirect = false
            
            if Config.SilentAimSurvivor and IsKillerPlayer(CurrentTarget) then
                ShouldRedirect = true
            elseif Config.SilentAimVeil and not IsKillerPlayer(CurrentTarget) then
                ShouldRedirect = true
            end

            if ShouldRedirect then
                local TargetPart = CurrentTarget.Character.HumanoidRootPart
                
                -- Kalkulasi Prediksi Pergerakan Super OP
                local Velocity = TargetPart.AssemblyLinearVelocity
                local Distance = (TargetPart.Position - Camera.CFrame.Position).Magnitude
                local PredictionTime = Distance / 950 
                local PredictedPosition = TargetPart.Position + (Velocity * PredictionTime) + Vector3.new(0, 0.15, 0)

                -- MEKANIK TRACER ORANGE (Hanya Muncul Pas Nembak Killer & Lurus Bergaransi)
                if Config.SilentAimSurvivor and IsKillerPlayer(CurrentTarget) then
                    task.spawn(function()
                        local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if MyRoot then
                            local StartPos, StartOnScreen = Camera:WorldToViewportPoint(MyRoot.Position)
                            local EndPos, EndOnScreen = Camera:WorldToViewportPoint(PredictedPosition)
                            
                            if StartOnScreen and EndOnScreen then
                                SurvivorTracer.From = Vector2.new(StartPos.X, StartPos.Y)
                                SurvivorTracer.To = Vector2.new(EndPos.X, EndPos.Y)
                                SurvivorTracer.Visible = true
                                
                                -- SISTEM HILANG OTOMATIS: Begitu deteksi hit terdaftar/selesai diproses, langsung hilang instan!
                                local OldHit = Method
                                if OldHit then
                                    task.wait(0.05) -- Durasi flash kilat peluru saat hantaman
                                    SurvivorTracer.Visible = false
                                end
                            end
                        end
                    end)
                end

                -- Eksekusi Manipulasi Arah Peluru Bergaransi Anti-Miss
                if Args[1] and typeof(Args[1]) == "Ray" then
                    Args[1] = Ray.new(Args[1].Origin, (PredictedPosition - Args[1].Origin).Unit * 9999)
                elseif Method == "Raycast" and typeof(Args[1]) == "Vector3" and typeof(Args[2]) == "Vector3" then
                    Args[2] = (PredictedPosition - Args[1]).Unit * 9999
                end
            end
        end
    end
    return OldNamecall(Self, unpack(Args))
end)
