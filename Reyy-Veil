-- [[ DETEKSI TIM & ROLE KETAT ]] --
local function IsKillerPlayer(player)
    if player:GetAttribute("Role") == "Killer" or player.Name:lower():find("killer") or (player.Character and player.Character:FindFirstChild("Tombak")) then
        return true
    end
    return false
end

local function GetClosestTarget(targetType)
    local Target = nil
    local ShortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local isKiller = IsKillerPlayer(v)
                local isValid = false
                
                if targetType == "KillerOnly" and isKiller then
                    isValid = true
                elseif targetType == "SurvivorOnly" and not isKiller then
                    isValid = true
                end

                if isValid then
                    local Dist = (v.Character.HumanoidRootPart.Position - Camera.CFrame.Position).Magnitude
                    if Dist < ShortestDistance then
                        ShortestDistance = Dist
                        Target = v
                    end
                end
            end
        end
    end
    return Target
end

-- [[ INTERFACE CANVAS TRACER (SISTEM MOBILE LIGHTWEIGHT) ]] --
local CanvasGui = Instance.new("Folder")
CanvasGui.Name = "ReyHub_Tracers_V11"
CanvasGui.Parent = ScreenGui

local function DrawMobileTracer(startPos3D, endPos3D, color)
    local LineFrame = Instance.new("Frame")
    LineFrame.BackgroundColor3 = color
    LineFrame.BorderSizePixel = 0
    LineFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    LineFrame.Parent = CanvasGui

    local function UpdateLine()
        if not LineFrame or not LineFrame.Parent then return end
        local StartPos, StartOnScreen = Camera:WorldToViewportPoint(startPos3D)
        local EndPos, EndOnScreen = Camera:WorldToViewportPoint(endPos3D)

        if StartOnScreen and EndOnScreen then
            local Distance = (Vector2.new(EndPos.X, EndPos.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
            local Angle = math.atan2(EndPos.Y - StartPos.Y, EndPos.X - StartPos.X)

            LineFrame.Size = UDim2.new(0, Distance, 0, 3) 
            LineFrame.Position = UDim2.new(0, (StartPos.X + EndPos.X) / 2, 0, (StartPos.Y + EndPos.Y) / 2)
            LineFrame.Rotation = math.deg(Angle)
            LineFrame.Visible = true
        else
            LineFrame.Visible = false
        end
    end

    local Connection = RunService.RenderStepped:Connect(UpdateLine)
    
    -- Efek kilat: Garis langsung hancur otomatis setelah 0.07 detik (Anti-Stuck Peluru)
    task.delay(0.07, function()
        Connection:Disconnect()
        LineFrame:Destroy()
    end)
end

-- [[ CORE RENDERING LOOP (VISUAL ONLY - ANTI-LAG & ANTI-STUCK) ]] --
RunService.RenderStepped:Connect(function()
    -- Cek Target Real-time berdasarkan status role saat ini
    local IAmKiller = IsKillerPlayer(LocalPlayer)
    
    if IAmKiller and Config.SilentAimVeil then
        CurrentTarget = GetClosestTarget("SurvivorOnly")
    elseif not IAmKiller and Config.SilentAimSurvivor then
        CurrentTarget = GetClosestTarget("KillerOnly")
    else
        CurrentTarget = nil
    end

    -- Sistem Chams Efisien
    if Config.ChamsKiller then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local Highlight = p.Character:FindFirstChildOfClass("Highlight")
                local killerCheck = IsKillerPlayer(p)

                if killerCheck then
                    if not Highlight then Highlight = Instance.new("Highlight", p.Character) end
                    Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    Highlight.FillTransparency = 0.4
                else
                    if not Highlight then Highlight = Instance.new("Highlight", p.Character) end
                    Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                    Highlight.FillTransparency = 0.4
                end
            end
        end
    end
end)

-- [[ HIGH-TIER METAMETHOD INJECTION (ANTI-MISS MUTLAK) ]] --
local OldIndex
OldIndex = hookmetamethod(game, "__index", function(Self, Key)
    if not checkcaller() then
        
        -- 1. KONDISI JIKA KAMU ADALAH KILLER (VEIL) -> MENGINCAR SURVIVOR
        if Config.SilentAimVeil and CurrentTarget and not IsKillerPlayer(CurrentTarget) then
            if CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
                local TargetRoot = CurrentTarget.Character.HumanoidRootPart
                
                -- Intersepsi data fisik Tombak agar langsung masuk ke koordinat target
                if Key == "CFrame" and (Self.Name:lower():find("tombak") or Self.Name:lower():find("spear") or Self.Name:lower():find("handle")) then
                    return TargetRoot.CFrame
                elseif Key == "Position" and (Self.Name:lower():find("tombak") or Self.Name:lower():find("spear")) then
                    return TargetRoot.Position
                end
            end
        end

        -- 2. KONDISI JIKA KAMU ADALAH SURVIVOR -> MENGINCAR KILLER
        if Config.SilentAimSurvivor and CurrentTarget and IsKillerPlayer(CurrentTarget) then
            if CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
                local TargetRoot = CurrentTarget.Character.HumanoidRootPart
                
                -- Intersepsi data peluru pistol agar otomatis berpindah ke tubuh Killer
                if Key == "CFrame" and (Self.Name:lower():find("bullet") or Self.Name:lower():find("peluru") or Self.Name:lower():find("pistol")) then
                    
                    -- Gambar Tracer Line Orange instan (Hanya muncul dari Survivor ke Killer)
                    local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if MyRoot then
                        task.spawn(function()
                            DrawMobileTracer(MyRoot.Position, TargetRoot.Position, Color3.fromRGB(255, 110, 0))
                        end)
                    end
                    
                    return TargetRoot.CFrame
                end
            end
        end
    end
    return OldIndex(Self, Key)
end)
