-- REAL HEAL AURA BYPASS MECHANICS
task.spawn(function()
    while task.wait(0.1) do
        if Features.HealAura and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local root = LocalPlayer.Character.HumanoidRootPart
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            
            -- Trigger healing server-side
            if hum and hum.Health < hum.MaxHealth then
                pcall(function()
                    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
                        if remote:IsA("RemoteEvent") and (remote.Name:lower():find("heal") or remote.Name:lower():find("med")) then
                            remote:FireServer()
                        end
                    end
                end)
            end
            
            -- Auto-Revive Sekutu
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    if (root.Position - player.Character.HumanoidRootPart.Position).Magnitude <= 14 then
                        for _, prompt in pairs(player.Character:GetDescendants()) do
                            if prompt:IsA("ProximityPrompt") then
                                fireproximityprompt(prompt)
                            end
                        end
                    end
                end
            end
            
            -- Efek Aura Ungu Real-Time Sesuai Video Rekaman
            local p = Instance.new("Part")
            p.Size = Vector3.new(2.5, 0.1, 2.5)
            p.CFrame = root.CFrame * CFrame.new(0, -2.4, 0)
            p.Anchored = true
            p.CanCollide = false
            p.Color = Color3.fromRGB(175, 0, 255)
            p.Material = Enum.Material.Neon
            p.Transparency = 0.4
            p.Parent = workspace
            
            local m = Instance.new("SpecialMesh")
            m.MeshType = Enum.MeshType.Cylinder
            m.Parent = p
            
            TweenService:Create(p, TweenInfo.new(0.2), {Size = Vector3.new(7, 0.05, 7), Transparency = 1}):Play()
            game:GetService("Debris"):AddItem(p, 0.2)
        end
    end
end)

-- TWIST OF FATE (OPTIMIZED AIMLOCK MURNI - ANTI-STUCK KAMERA MOBILE)
RunService.RenderStepped:Connect(function()
    if Features.TwistOfFate and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local targetPlayer, _ = fetchTargetKiller()
        if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local killerRoot = targetPlayer.Character.HumanoidRootPart
            
            -- Hanya berputar mengunci saat menekan/menggunakan senjata (Tool) agar kontrol analog gerak jari tidak kaku/stuck
            local heldTool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if heldTool then
                local rawLookPosition = Vector3.new(killerRoot.Position.X, LocalPlayer.Character.HumanoidRootPart.Position.Y, killerRoot.Position.Z)
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(LocalPlayer.Character.HumanoidRootPart.Position, rawLookPosition)
            end
        end
    end
end)
