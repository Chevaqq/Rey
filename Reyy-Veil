local function IsKiller(player)
    if player == LocalPlayer then return false end
    if player.Team and (player.Team.Name:lower():find("killer") or player.Team.Name:lower():find("slasher")) then
        return true
    end
    local character = player.Character
    if character then
        for _, item in pairs(character:GetChildren()) do
            if item:IsA("Tool") and (item.Name:lower():find("knife") or item.Name:lower():find("weapon") or item.Name:lower():find("murd")) then
                return true
            end
        end
    end
    return false
end

-- --- FEATURE A: CHAMS KILLER (FULL MERAH TANPA OUTLINE) ---
local function ApplyKillerChams(player)
    player.CharacterAdded:Connect(function(char)
        if IsKiller(player) then
            task.wait(0.5)
            if char:FindFirstChild("CyberChams") then char.CyberChams:Destroy() end
            
            local box = Instance.new("Highlight")
            box.Name = "CyberChams"
            box.FillColor = Color3.fromRGB(255, 0, 0)
            box.FillTransparency = 0 
            box.OutlineTransparency = 1 
            box.Adornee = char
            box.Parent = char
        end
    end)
    
    if player.Character and IsKiller(player) then
        local char = player.Character
        if char:FindFirstChild("CyberChams") then char.CyberChams:Destroy() end
        local box = Instance.new("Highlight")
        box.Name = "CyberChams"
        box.FillColor = Color3.fromRGB(255, 0, 0)
        box.FillTransparency = 0
        box.OutlineTransparency = 1
        box.Adornee = char
        box.Parent = char
    end
end

-- --- FEATURE B: ADVANCED KILLER DETECTOR (! & ✓ PROXIMITY) ---
local function ManageKillerDetector(player)
    local function setupBillboard(char)
        if not IsKiller(player) then return end
        
        local bboard = Instance.new("BillboardGui")
        bboard.Name = "KillerDetectorUI"
        bboard.Size = UDim2.new(0, 100, 0, 50)
        bboard.AlwaysOnTop = true
        bboard.ExtentsOffset = Vector3.new(0, 3, 0)
        bboard.Adornee = char:FindFirstChild("Head")
        bboard.Parent = char

        local indicatorText = Instance.new("TextLabel")
        indicatorText.Size = UDim2.new(1, 0, 1, 0)
        indicatorText.BackgroundTransparency = 1
        indicatorText.Font = Enum.Font.Code
        indicatorText.TextSize = 26
        indicatorText.TextColor3 = Color3.fromRGB(255, 0, 0)
        indicatorText.Text = ""
        indicatorText.Parent = bboard

        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not char:IsDescendantOf(workspace) or not char:FindFirstChild("HumanoidRootPart") or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                connection:Disconnect()
                return
            end
            
            local dist = (char.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist <= 50 then
                if dist <= 20 then
                    indicatorText.Text = "!!!"
                    indicatorText.TextColor3 = Color3.fromRGB(255, 0, 0)
                else
                    indicatorText.Text = "!"
                    indicatorText.TextColor3 = Color3.fromRGB(255, 100, 0)
                end
            elseif dist > 50 and dist <= 80 then
                indicatorText.Text = "✓"
                indicatorText.TextColor3 = Color3.fromRGB(0, 255, 0)
            else
                indicatorText.Text = "" 
            end
        end)
    end

    player.CharacterAdded:Connect(setupBillboard)
    if player.Character then setupBillboard(player.Character) end
end

local function GetKillerInFov()
    local target = nil
    local maxDistance = ScriptConfig.FovRadius

    for _, player in pairs(Players:GetPlayers()) do
        if IsKiller(player) and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local root = player.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen then
                local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                
                if distance < maxDistance then
                    maxDistance = distance
                    target = root
                end
            end
        end
    end
    return target
end

