-- Mengatasi masalah UI hilang: Gunakan CoreGui atau deteksi loop untuk PlayerGui
local function getSafeGui()
    local success, currentGui = pcall(function() return CoreGui end)
    if success and currentGui then return currentGui end
    
    local success2, playerGui = pcall(function() return LocalPlayer:WaitForChild("PlayerGui", 5) end)
    if success2 and playerGui then return playerGui end
    
    return nil
end

