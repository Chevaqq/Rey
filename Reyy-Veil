-- [2] LOGIKA UTAMA MOONWALK (IKUTI KAMERA + ANTI RESET IN-GAME)
local function StartMoonwalk()
    if moonwalkConnection then moonwalkConnection:Disconnect() end
    
    moonwalkConnection = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            
            if hum and root then
                -- MATIKAN AUTOROTATE GAME: Supaya script game gak maksa badan madep depan
                hum.AutoRotate = false
                
                -- Cek apakah karakter lagi jalan (pake analog/WAsD)
                if hum.MoveDirection.Magnitude > 0 then
                    -- Ambil arah hadap kamera saat ini
                    local lookVector = Camera.CFrame.LookVector
                    -- Balikkan arah CFrame (Kamera depan = Karakter madep belakang)
                    root.CFrame = CFrame.new(root.Position, root.Position - Vector3.new(lookVector.X, 0, lookVector.Z))
                end
            end
        end
    end)
end

local function StopMoonwalk()
    if moonwalkConnection then
        moonwalkConnection:Disconnect()
        moonwalkConnection = nil
    end
    
    -- Kembalikan fungsi AutoRotate normal game jika dimatikan
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.AutoRotate = true
        end
    end
end

-- Fitur Auto-Reattach saat Karakter Reset/Spawn Baru di In-Game
LocalPlayer.CharacterAdded:Connect(function(newChar)
    task.wait(0.5) -- Beri jeda loading game saat masuk map
    if moonwalkActive then
        StartMoonwalk()
    end
end)

