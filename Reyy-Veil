        ToggleBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 60) -- Hijau
        StartMoonwalk()
    else
        ToggleBtn.Text = "STATUS: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60) -- Merah
