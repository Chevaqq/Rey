-- [[ MAIN RENDERING ENGINE ]] --
RunService.RenderStepped:Connect(function()
    local IAmKiller = IsKillerPlayer(LocalPlayer)
    
    -- Pemilihan Target Otomatis Berdasarkan Peran
    if IAmKiller and Config.AimlockVeil then
        CurrentTarget = GetClosestTarget("SurvivorOnly")
    elseif not IAmKiller and Config.SilentAimSurvivor then
        CurrentTarget = GetClosestTarget("KillerOnly")
    else
        CurrentTarget = nil
    end

    -- Visual ESP Chams
    if Config.ChamsVisuals then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local Highlight = p.Character:FindFirstChildOfClass("Highlight")
                if not Highlight then Highlight = Instance.new("Highlight", p.Character) end
                Highlight.FillColor = IsKillerPlayer(p) and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
                Highlight.FillTransparency = 0.5
            end
        end
    end

    -- EKSEKUSI VEIL AIMLOCK (PERSIS SEPERTI DI VIDEO + SISTEM ANTI-STUCK)
    if IAmKiller and Config.AimlockVeil and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        -- Jika jari kamu sedang menggeser layar manual, kunci kamera dijeda agar tidak macet/stuck
        if not IsTouchingScreen then
            local TargetRoot = CurrentTarget.Character.HumanoidRootPart
            local Distance = (TargetRoot.Position - Camera.CFrame.Position).Magnitude
            
            -- Perhitungan Prediksi Kecepatan Target (Anti-Miss Bergerak)
            local PredictionFactor = Distance / 850 
            local PredictedPosition = TargetRoot.Position + (TargetRoot.AssemblyLinearVelocity * PredictionFactor) + Vector3.new(0, 0.2, 0)
            
            -- Perputaran Kamera Menggunakan Metode Smooth Lerp
            local NewLookAt = CFrame.lookAt(Camera.CFrame.Position, PredictedPosition)
            Camera.CFrame = Camera.CFrame:Lerp(NewLookAt, Config.AimbotSmoothness)
        end
    end
end)

-- [[ INTERSEPSI SERVER (ANTI-MISS MUTLAK) ]] --
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()

    if not checkcaller() and (Method == "Raycast" or Method == "FindPartOnRayWithIgnoreList") then
        if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local TargetRoot = CurrentTarget.Character.HumanoidRootPart
            local Distance = (TargetRoot.Position - Camera.CFrame.Position).Magnitude
            local PredictedPosition = TargetRoot.Position + (TargetRoot.AssemblyLinearVelocity * (Distance / 850))

            -- Kondisi 1: Jika kamu Survivor menembak Killer -> Muncul Tracer Orange
            if not IsKillerPlayer(LocalPlayer) and Config.SilentAimSurvivor and IsKillerPlayer(CurrentTarget) then
                local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if MyRoot then
                    task.spawn(function() DrawOrangeTracer(MyRoot.Position, TargetRoot.Position) end)
                end
            end

            -- Pembelokan Proyektil Server untuk Menjamin Serangan Masuk (Anti-Miss)
            if Method == "Raycast" and typeof(Args[1]) == "Vector3" and typeof(Args[2]) == "Vector3" then
                Args[2] = (PredictedPosition - Args[1]).Unit * 9999
            elseif Args[1] and typeof(Args[1]) == "Ray" then
                Args[1] = Ray.new(Args[1].Origin, (PredictedPosition - Args[1].Origin).Unit * 9999)
            end
        end
    end
    return OldNamecall(Self, unpack(Args))
end)
