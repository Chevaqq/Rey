    local function CreateToggle(parent, text, isVipFeature, callback)
        local displayName = text
        if isVipFeature then displayName = text .. " *" end

        local ToggleFrame = Instance.new("Frame")
        ToggleFrame.Size = UDim2.new(0, 380, 0, 35)
        ToggleFrame.BackgroundTransparency = 1
        ToggleFrame.Parent = parent

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(0, 250, 1, 0)
        Label.BackgroundTransparency = 1
        Label.Text = displayName
        Label.TextColor3 = isVipFeature and Color3.fromRGB(255, 180, 0) or Color3.fromRGB(220, 220, 220)
        Label.Font = Enum.Font.Code
        Label.TextSize = 13
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = ToggleFrame

        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(0, 50, 0, 24)
        Btn.Position = UDim2.new(1, -60, 0.5, -12)
        Btn.BackgroundColor3 = Color3.fromRGB(30, 10, 10)
        Btn.Text = "OFF"
        Btn.TextColor3 = Color3.fromRGB(255, 50, 50)
        Btn.Font = Enum.Font.Code
        Btn.TextSize = 11
        Btn.Parent = ToggleFrame
        
        local state = false
        
        local function toggle(forcedState)
            if forcedState ~= nil then state = forcedState else state = not state end
            if state then
                Btn.BackgroundColor3 = Color3.fromRGB(10, 40, 10)
                Btn.Text = "ON"
                Btn.TextColor3 = Color3.fromRGB(50, 255, 50)
            else
                Btn.BackgroundColor3 = Color3.fromRGB(30, 10, 10)
                Btn.Text = "OFF"
                Btn.TextColor3 = Color3.fromRGB(255, 50, 50)
            end
            callback(state)
        end

        Btn.MouseButton1Click:Connect(function()
            if isVipFeature and UserStatus ~= "VIP" then
                ShowNotification("No Access VIP!")
                return
            end
            toggle()
        end)
        
        return toggle
    end

