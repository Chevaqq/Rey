-- SILENT AIM (LOCK ON KILLER ONLY)
-- Berfungsi mendeteksi player yang bertindak sebagai "Killer" di dalam game Violence District
local function getClosestKiller()
    local closestTarget = nil
    local shortestDistance = math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            -- Validasi spesifik status Killer (berdasarkan Tools senjata pembunuh atau NameTag merah khas game)
            local isKiller = false
            if player.Character:FindFirstChildOfClass("Tool") or player:FindFirstChild("Role") and player.Role.Value == "Killer" then
                isKiller = true
            elseif player.Character:FindFirstChild("Head") and player.Character.Head:FindFirstChild("Nametag") then
                isKiller = true -- Menyesuaikan UI bawaan Violence District
            end
            
            if isKiller then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    -- Hitung jarak dari kursor tengah layar HP
                    local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    
                    if distance < shortestDistance and distance < 300 then -- Radius FOV Ring Lock
                        shortestDistance = distance
                        closestTarget = player.Character.HumanoidRootPart
                    end
                end
            end
        end
    end
    return closestTarget
end

-- Interseksi Hook metatable index untuk membelokkan peluru/serangan ke Target Killer secara instan
local gmt = getrawmetatable(game)
setreadonly(gmt, false)
local oldNamecall = gmt.__namecall

gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if Features.SilentAim and (method == "FindPartOnRayWithIgnoreList" or method == "Raycast") then
        local target = getClosestKiller()
        if target then
            -- Mengubah arah tembakan/serangan siber langsung menuju hitbox Killer
            if method == "FindPartOnRayWithIgnoreList" then
                args[1] = Ray.new(Camera.CFrame.Position, (target.Position - Camera.CFrame.Position).Unit * 1000)
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(gmt, true)
