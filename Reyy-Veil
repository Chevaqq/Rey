-- [[ REYHUB / ACCOORNNHUB - VIOLENCE DISTRICT VEIL ONLY ]] --

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Konfigurasi Fitur Utama (Otomatis Aktif Tanpa UI/Key)
local Config = {
    ChamsSurvivor = true,     -- Mengaktifkan Chams Hijau pada Survivor
    SilentAimVeil = true,     -- Mengaktifkan Kunci & Prediksi Tombak ke Survivor
    AimbotSmoothness = 0.15   -- Tingkat kehalusan kamera (makin kecil makin nempel seperti di video)
}

-- [[ UTILITY: MEMASTIKAN TARGET ADALAH SURVIVOR ]] --
local function IsSurvivor(player)
    -- Memastikan target bukan Killer dan bukan diri sendiri
    if player ~= LocalPlayer and player:GetAttribute("Role") ~= "Killer" and not player.Name:lower():find("killer") then
        return true
    end
    return false
end

-- [[ MENCARI SURVIVOR TERDEKAT DENGAN KURSOR LAYAR ]] --
local function GetClosestSurvivor()
    local Target = nil
    local ShortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if IsSurvivor(v) and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Humanoid = v.Character:FindFirstChildOfClass("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                -- Hitung jarak dari tengah layar ke posisi Survivor
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if OnScreen then
                    local MousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local Mag = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                    if Mag < ShortestDistance then
                        ShortestDistance = Mag
                        Target = v
                    end
                end
            end
        end
    end
    return Target
end

-- [[ LOOP UTAMA: CHAMS DAN KAMERA VEIL SMOOTH ]] --
RunService.RenderStepped:Connect(function()
    local CurrentTarget = GetClosestSurvivor()

    -- 1. EKSEKUSI CHAMS SURVIVOR (Warna Hijau murni seperti di video)
    for _, p in pairs(Players:GetPlayers()) do
        if IsSurvivor(p) and p.Character then
            local Highlight = p.Character:FindFirstChildOfClass("Highlight")
            if Config.ChamsSurvivor then
                if not Highlight then
                    Highlight = Instance.new("Highlight")
                    Highlight.Parent = p.Character
                end
                Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                Highlight.FillTransparency = 0.5
                Highlight.OutlineTransparency = 0
                Highlight.Enabled = true
            else
                if Highlight then Highlight:Destroy() end
            end
        end
    end

    -- 2. EKSEKUSI TRACKING KAMERA VEIL (Sistem Smooth Lerp Anti-Stuck)
    if Config.SilentAimVeil and CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local TargetRoot = CurrentTarget.Character.HumanoidRootPart
        
        -- Menghitung prediksi pergerakan berdasarkan kecepatan jalan Survivor
        local TargetVelocity = TargetRoot.AssemblyLinearVelocity
        local Distance = (TargetRoot.Position - Camera.CFrame.Position).Magnitude
        local TimeToHit = Distance / 850 -- Kecepatan rata-rata lemparan tombak Veil
        
        -- Titik bidik hasil prediksi pergerakan target
        local PredictedPos = TargetRoot.Position + (TargetVelocity * TimeToHit) + Vector3.new(0, 0.2, 0)

        -- Memutar kamera secara halus ke arah posisi prediksi
        -- Metode Lerp ini memberikan efek 'tarikan' magnet ke musuh tanpa mengunci paksa kontrol jari kamu
        local NewCameraCFrame = CFrame.lookAt(Camera.CFrame.Position, PredictedPos)
        Camera.CFrame = Camera.CFrame:Lerp(NewCameraCFrame, Config.AimbotSmoothness)
    end
end)

-- [[ INTERSEPSI METAMETHOD UNTUK MEMASTIKAN TOMBAK JATUH TEPAT SASARAN ]] --
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()

    -- Jika fitur aktif dan sedang melempar tombak (Raycast dideteksi)
    if Config.SilentAimVeil and (Method == "Raycast" or Method == "FindPartOnRayWithIgnoreList") then
        local CurrentTarget = GetClosestSurvivor()
        if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            local TargetRoot = CurrentTarget.Character.HumanoidRootPart
            
            -- Belokkan arah lemparan tombak secara internal tepat ke dada Survivor terdekat
            if Method == "Raycast" and typeof(Args[1]) == "Vector3" and typeof(Args[2]) == "Vector3" then
                Args[2] = (TargetRoot.Position - Args[1]).Unit * 9999
            elseif Args[1] and typeof(Args[1]) == "Ray" then
                Args[1] = Ray.new(Args[1].Origin, (TargetRoot.Position - Args[1].Origin).Unit * 9999)
            end
        end
    end
    return OldNamecall(Self, unpack(Args))
end)
