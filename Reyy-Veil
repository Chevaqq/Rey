    if Features.SilentAim and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local targetKiller = getClosestKiller()
        if targetKiller then
            -- Modifikasi arah hit vektor lokal peluru/pukulan langsung mengarah ke posisi Killer
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChild("Activated") then
                    -- Mengarahkan serangan langsung ke Hitbox Killer secara halus tanpa merusak analog kamera
                    local lookVector = (targetKiller.Position - Camera.CFrame.Position).Unit
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + lookVector)
                end
            end)
        end
    end
end)
