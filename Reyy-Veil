-- Fungsi Notifikasi Cyber
local function ShowNotification(text)
    local Notif = Instance.new("TextLabel")
    Notif.Size = UDim2.new(0, 280, 0, 45)
    Notif.Position = UDim2.new(0.5, -140, 0.15, 0)
    Notif.BackgroundColor3 = Color3.fromRGB(5, 5, 15)
    Notif.TextColor3 = Color3.fromRGB(0, 180, 255)
    Notif.TextSize = 14
    Notif.Font = Enum.Font.Code
    Notif.Text = "[CHEVA HUB] " .. text
    Notif.BorderSizePixel = 1
    Notif.BorderColor3 = Color3.fromRGB(0, 100, 255)
    Notif.Parent = ScreenGui

    task.delay(2.5, function()
        local t = TweenService:Create(Notif, TweenInfo.new(0.4), {TextTransparency = 1, BackgroundTransparency = 1})
        t:Play()
        t.Completed:Wait()
        Notif:Destroy()
    end)
end

