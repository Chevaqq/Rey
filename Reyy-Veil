-- [2] LOGIKA MOONWALK (ANTI-STUCK / RESPONSif)
local function ToggleMoonwalk()
    moonwalkActive = not moonwalkActive
    
    if moonwalkActive then
        ToggleBtn.Text = "STATUS: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 205, 50) -- Hijau saat Aktif
        
        moonwalkConnection = RunService.RenderStepped:Connect(function()
            local char = LocalPlayer.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local root = char:FindFirstChild("HumanoidRootPart")
                
                -- Hanya berputar kalau karakter sedang bergerak (biar kamera gak stuck/ngebug)
                if hum and root and hum.MoveDirection.Magnitude > 0 then
                    local moveDir = hum.MoveDirection
                    -- Memaksa HRP menghadap kebalikan arah jalan
                    root.CFrame = CFrame.new(root.Position, root.Position - moveDir)
                end
            end
        end)
    else
        ToggleBtn.Text = "STATUS: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50) -- Merah saat Mati
        
        if moonwalkConnection then
            moonwalkConnection:Disconnect()
            moonwalkConnection = nil
        end
    end
end

-- [3] ASSIGN FUNGSI TOMBOL
ToggleBtn.MouseButton1Click:Connect(ToggleMoonwalk)

